<%- include("../partials/head", { title: "Detalhes da Venda" }) %>
<%- include("../partials/sidebar") %>
<h2 class="text-2xl font-bold mb-4">Venda #<%= sale.id %></h2>
<div class="bg-white rounded-xl shadow border border-slate-100 p-5 mb-4">
  <p><strong>Cliente:</strong> <%= sale.cliente_nome || "Consumidor final" %></p>
  <p><strong>CPF:</strong> <%= sale.cpf || "-" %></p>
  <p><strong>Telefone:</strong> <%= sale.telefone || "-" %></p>
  <p><strong>Email:</strong> <%= sale.email || "-" %></p>
  <p><strong>Endereço:</strong> <%= sale.endereco || "-" %></p>
  <p class="mt-3"><strong>Forma de pagamento:</strong> <%= sale.forma_pagamento %></p>
  <% if (Number(sale.pagamento_dinheiro) > 0) { %>
    <p><strong>Parte em dinheiro:</strong> R$ <%= Number(sale.pagamento_dinheiro).toFixed(2) %></p>
  <% } %>
  <% if (Number(sale.pagamento_pix) > 0) { %>
    <p><strong>Parte no Pix:</strong> R$ <%= Number(sale.pagamento_pix).toFixed(2) %></p>
  <% } %>
  <% if (Number(sale.pagamento_cartao) > 0) { %>
    <p><strong>Parte no cartão:</strong> R$ <%= Number(sale.pagamento_cartao).toFixed(2) %>
      <% if (Number(sale.parcelas) > 1) { %>(<%= sale.parcelas %>x)<% } %>
    </p>
  <% } %>
  <p><strong>Total:</strong> R$ <%= Number(sale.total).toFixed(2) %></p>
  <p><strong>Valor pago:</strong> R$ <%= Number(sale.valor_pago).toFixed(2) %> · <strong>Troco:</strong> R$ <%= Number(sale.troco).toFixed(2) %></p>
  <a href="/vendas/recibo/<%= sale.id %>" class="inline-block mt-3 bg-slate-900 text-white px-4 py-2 rounded-lg">Abrir recibo</a>
</div>
<div class="bg-white rounded-xl shadow border border-slate-100 p-5">
  <h3 class="font-semibold mb-2">Itens</h3>
  <% items.forEach((i) => { %>
    <div class="flex justify-between border-b py-2">
      <span><%= i.nome %> x <%= i.quantidade %></span>
      <span>R$ <%= Number(i.subtotal).toFixed(2) %></span>
    </div>
  <% }) %>
</div>
<%- include("../partials/footer") %>
