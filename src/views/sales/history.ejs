<%- include("../partials/head", { title: "Histórico de Vendas" }) %>
<%- include("../partials/sidebar") %>
<h2 class="text-2xl font-bold mb-4">Histórico de Vendas</h2>
<form class="bg-white p-4 rounded-xl shadow mb-4 flex flex-wrap gap-3 items-end">
  <div><label class="text-sm">De</label><input type="date" name="startDate" value="<%= startDate || '' %>" class="border rounded px-2 py-1"></div>
  <div><label class="text-sm">Até</label><input type="date" name="endDate" value="<%= endDate || '' %>" class="border rounded px-2 py-1"></div>
  <button class="bg-brand-600 text-white px-4 py-2 rounded">Filtrar</button>
</form>
<div class="bg-white rounded-xl shadow overflow-auto">
  <table class="w-full text-sm">
    <thead class="bg-slate-50"><tr><th class="p-3">ID</th><th class="p-3">Cliente</th><th class="p-3">Total</th><th class="p-3">Pagamento</th><th class="p-3">Data</th><th class="p-3">Detalhes</th></tr></thead>
    <tbody>
      <% sales.forEach((s) => { %>
      <tr class="border-t">
        <td class="p-3 text-center"><%= s.id %></td>
        <td class="p-3 text-center"><%= s.cliente_nome || "Consumidor final" %></td>
        <td class="p-3 text-center">R$ <%= Number(s.total).toFixed(2) %></td>
        <td class="p-3 text-center"><%= s.forma_pagamento %></td>
        <td class="p-3 text-center"><%= new Date(s.created_at).toLocaleString("pt-BR") %></td>
        <td class="p-3 text-center"><a class="text-blue-600" href="/historico/<%= s.id %>">Ver</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include("../partials/footer") %>
