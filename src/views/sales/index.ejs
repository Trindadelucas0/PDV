<%- include("../partials/head", { title: "PDV" }) %>
<%- include("../partials/sidebar") %>

<section class="bg-neutral-900 border border-amber-500/20 rounded-2xl p-6 mb-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h2 class="text-3xl font-bold text-amber-100 mb-1">Vendas / Caixa</h2>
      <p class="text-sm text-slate-300">Digite nome ou código de barras e finalize com segurança.</p>
    </div>
    <button
      type="button"
      id="print_last_sale_btn"
      class="bg-amber-500 hover:bg-amber-400 disabled:opacity-60 disabled:cursor-not-allowed text-neutral-950 px-4 py-2 rounded-lg font-semibold transition-colors"
    >
      Imprimir última venda
    </button>
  </div>
</section>
<div id="toast_root" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none max-w-sm"></div>

<div class="grid lg:grid-cols-3 gap-5">
  <section class="lg:col-span-2 bg-neutral-900 rounded-xl border border-amber-500/20 p-5">
    <div class="flex items-center gap-2 mb-1">
      <label class="block text-sm font-medium text-amber-100">Buscar produto</label>
      <span id="busca_loading" class="hidden text-xs text-amber-300 font-medium">Buscando...</span>
    </div>
    <div class="relative mb-2">
      <input id="busca_produto" autocomplete="off" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2.5 pr-24 focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="Nome, parte do nome ou código de barras" />
      <button type="button" id="addBtn" class="absolute right-1 top-1 bottom-1 bg-brand-500 hover:bg-brand-600 disabled:opacity-60 disabled:cursor-not-allowed text-neutral-950 px-3 rounded-md text-sm font-semibold transition-colors min-w-[5.5rem]">Adicionar</button>
      <div id="sugestoes" class="hidden absolute z-20 left-0 right-0 mt-1 bg-neutral-950 border border-amber-500/25 rounded-lg shadow-2xl max-h-56 overflow-auto"></div>
    </div>
    <p class="text-xs text-slate-400 mb-4">A partir de 1 letra já busca na lista. Código completo adiciona direto.</p>

    <div class="overflow-auto rounded-lg border border-slate-700">
      <table class="w-full text-sm" id="itemsTable">
        <thead class="bg-neutral-950 text-amber-100">
          <tr>
            <th class="p-2 text-left">Produto</th>
            <th class="p-2">Qtd</th>
            <th class="p-2">Preço</th>
            <th class="p-2">Subtotal</th>
            <th class="p-2">Ação</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </section>

  <section class="bg-neutral-900 rounded-xl border border-amber-500/20 p-5 space-y-4">
    <div>
      <h3 class="font-semibold text-amber-100 mb-2">Cliente</h3>
      <input id="cliente_nome" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 mb-2 focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="Nome" />
      <input id="cliente_cpf" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 mb-2 focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="CPF" />
      <input id="cliente_tel" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 mb-2 focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="Telefone" />
      <input id="cliente_email" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 mb-2 focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="Email" />
      <textarea id="cliente_endereco" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" rows="2" placeholder="Endereço"></textarea>
    </div>

    <div>
      <h3 class="font-semibold text-amber-100 mb-2">Pagamento</h3>
      <label class="block text-xs text-slate-400 mb-1">Forma principal</label>
      <select id="modo_pagamento" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 mb-3 focus:outline-none focus:ring-2 focus:ring-amber-500">
        <option value="Dinheiro">Dinheiro</option>
        <option value="Pix">Pix</option>
        <option value="Cartão débito">Cartão débito</option>
        <option value="Cartão crédito">Cartão crédito</option>
        <option value="Misto">Misto (dinheiro + cartão / pix)</option>
      </select>
      <div class="grid grid-cols-2 gap-2 mb-3">
        <button type="button" class="modo-rapido bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 text-sm hover:border-amber-500/50" data-modo="Dinheiro">Dinheiro</button>
        <button type="button" class="modo-rapido bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 text-sm hover:border-amber-500/50" data-modo="Pix">Pix</button>
        <button type="button" class="modo-rapido bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 text-sm hover:border-amber-500/50" data-modo="Cartão débito">Cartão débito</button>
        <button type="button" class="modo-rapido bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 text-sm hover:border-amber-500/50" data-modo="Cartão crédito">Cartão crédito</button>
      </div>

      <div id="painel_dinheiro" class="space-y-2">
        <label class="block text-xs text-slate-400">Valor recebido (dinheiro)</label>
        <input id="valor_recebido" type="number" step="0.01" min="0" value="0" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="0,00" />
      </div>

      <div id="painel_pix" class="hidden text-sm text-slate-300 py-2">Pagamento integral via Pix (sem troco).</div>

      <div id="painel_cartao" class="hidden space-y-2">
        <label class="block text-xs text-slate-400">Parcelas no cartão (crédito)</label>
        <select id="parcelas_cartao" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500">
          <% for (let i = 1; i <= 12; i++) { %>
            <option value="<%= i %>"><%= i %>x</option>
          <% } %>
        </select>
      </div>

      <div id="painel_misto" class="hidden space-y-2">
        <p class="text-xs text-slate-400">Informe quanto entra em cada forma. A soma deve fechar o total da venda.</p>
        <div>
          <label class="block text-xs text-slate-400">Parte em dinheiro (R$)</label>
          <input id="parte_dinheiro" type="number" step="0.01" min="0" value="0" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" />
        </div>
        <div>
          <label class="block text-xs text-slate-400">Parte no cartão (R$)</label>
          <input id="parte_cartao" type="number" step="0.01" min="0" value="0" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" />
        </div>
        <div>
          <label class="block text-xs text-slate-400">Parte no Pix (R$) — opcional</label>
          <input id="parte_pix" type="number" step="0.01" min="0" value="0" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" />
        </div>
        <button type="button" id="btn_restante_cartao" class="text-sm text-amber-300 hover:text-amber-200 hover:underline">Usar o restante no cartão</button>
        <div>
          <label class="block text-xs text-slate-400">Parcelas (só sobre o valor no cartão)</label>
          <select id="parcelas_misto" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500">
            <% for (let i = 1; i <= 12; i++) { %>
              <option value="<%= i %>"><%= i %>x</option>
            <% } %>
          </select>
        </div>
        <div>
          <label class="block text-xs text-slate-400">Dinheiro que o cliente entregou (para calcular troco)</label>
          <input id="valor_recebido_dinheiro" type="number" step="0.01" min="0" value="0" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" />
        </div>
        <p id="misto_soma_hint" class="text-xs font-medium"></p>
      </div>
    </div>

    <div>
      <label class="block text-xs text-slate-400 mb-1">Desconto (R$)</label>
      <input id="desconto_valor" type="number" step="0.01" min="0" value="0" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" />
    </div>

    <div class="bg-neutral-950 border border-amber-500/30 rounded-lg p-4 text-sm">
      <p class="text-slate-300">Subtotal: <strong id="subtotal" class="text-slate-100">R$ 0.00</strong></p>
      <p class="text-slate-300">Desconto: <strong id="desconto" class="text-amber-200">R$ 0.00</strong></p>
      <p class="text-slate-300">Total: <strong id="total" class="text-amber-300 text-lg">R$ 0.00</strong></p>
      <p class="text-slate-300">Troco: <strong id="troco" class="text-amber-200">R$ 0.00</strong></p>
    </div>
    <button type="button" id="finishBtn" class="w-full bg-brand-500 hover:bg-brand-600 text-neutral-950 font-semibold py-3 rounded-lg transition-colors">Finalizar venda</button>
  </section>
</div>
<div id="receipt_modal" class="hidden fixed inset-0 z-[80] bg-neutral-950/80 p-4 overflow-y-auto items-center justify-center">
  <div class="w-full max-w-md my-auto bg-neutral-900 border border-amber-500/30 rounded-xl p-4 shadow-2xl">
    <p class="text-amber-100 font-semibold mb-1">Venda concluída</p>
    <p class="text-slate-300 text-sm mb-3">Abrir o recibo em outra guia para imprimir ou conferir.</p>
    <div id="receipt_modal_content" class="print-area max-h-[50vh] overflow-auto rounded border border-slate-700 bg-white p-2"></div>
    <div class="print:hidden mt-3 flex justify-end gap-2">
      <button type="button" id="receipt_yes_btn" class="bg-brand-500 hover:bg-brand-600 disabled:opacity-60 disabled:cursor-not-allowed text-neutral-950 px-4 py-2 rounded-lg font-semibold">Abrir recibo</button>
      <button type="button" id="receipt_no_btn" class="bg-neutral-800 hover:bg-neutral-700 text-slate-100 px-4 py-2 rounded-lg">Não</button>
    </div>
  </div>
</div>
<div id="pdv_loading_overlay" class="hidden fixed inset-0 z-[60] bg-neutral-950/75 backdrop-blur-sm items-center justify-center">
  <div class="bg-neutral-900 border border-amber-500/30 rounded-xl px-6 py-5 text-center max-w-xs">
    <div class="w-10 h-10 mx-auto border-4 border-amber-500/30 border-t-amber-400 rounded-full animate-spin mb-3"></div>
    <p id="pdv_loading_title" class="text-amber-100 font-medium">Aguarde</p>
    <p id="pdv_loading_detail" class="text-slate-300 text-xs mt-1">Processando no servidor.</p>
  </div>
</div>
<style>
  @media print {
    body > * {
      display: none !important;
    }
    #receipt_modal {
      display: block !important;
      position: static !important;
      background: #fff !important;
      padding: 0 !important;
    }
    #receipt_modal .print\\:hidden {
      display: none !important;
    }
    #receipt_modal_content {
      display: block !important;
      max-height: none !important;
      overflow: visible !important;
      border: none !important;
      padding: 0 !important;
    }
  }
</style>
<script src="/js/pdv.js"></script>
<%- include("../partials/footer") %>
