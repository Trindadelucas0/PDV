<div class="max-w-sm mx-auto bg-white p-4 border text-sm font-mono print:shadow-none text-black">
  <h1 class="text-center font-bold text-lg"><%= typeof store !== "undefined" && store.name ? store.name : "Controle PDV" %></h1>
  <% if (typeof store !== "undefined" && store.phone) { %><p class="text-center">Tel: <%= store.phone %></p><% } %>
  <% if (typeof store !== "undefined" && store.address) { %><p class="text-center text-xs"><%= store.address %></p><% } %>
  <hr class="my-3" />
  <p>Venda Nº: <%= sale.id %></p>
  <p>Data: <%= new Date(sale.created_at).toLocaleString("pt-BR") %></p>
  <p>Cliente: <%= sale.cliente_nome || "Consumidor Final" %></p>
  <p>CPF: <%= sale.cpf || "-" %></p>
  <hr class="my-3" />
  <% let subtotalBruto = 0; %>
  <% items.forEach((item) => { %>
    <% subtotalBruto += Number(item.subtotal || 0); %>
    <div class="flex justify-between gap-2">
      <span><%= item.nome %> x<%= item.quantidade %></span>
      <span>R$ <%= Number(item.subtotal).toFixed(2) %></span>
    </div>
  <% }) %>
  <hr class="my-3" />
  <p>Subtotal: R$ <%= Number(subtotalBruto).toFixed(2) %></p>
  <% if (Number(sale.desconto) > 0) { %>
    <p>Desconto: R$ <%= Number(sale.desconto).toFixed(2) %></p>
  <% } %>
  <p class="font-bold">Total da venda: R$ <%= Number(sale.total).toFixed(2) %></p>
  <p>Forma (cadastro): <%= sale.forma_pagamento %></p>
  <% const recs = typeof recebimentos !== "undefined" && recebimentos ? recebimentos : []; %>
  <% const recTotal = typeof recebidoAcumulado !== "undefined" ? Number(recebidoAcumulado) : recs.reduce((s, r) => s + Number(r.valor || 0), 0); %>
  <% const saldo = typeof saldoEmAberto !== "undefined" ? Number(saldoEmAberto) : Number(sale.total) - recTotal; %>
  <% if (recs.length > 0) { %>
    <hr class="my-2" />
    <p class="font-semibold">Recebimentos no caixa</p>
    <% recs.forEach((r) => { %>
      <p class="text-xs"><%= new Date(r.created_at).toLocaleString("pt-BR") %> — <%= r.forma_pagamento %> — R$ <%= Number(r.valor).toFixed(2) %></p>
    <% }) %>
  <% } %>
  <p class="mt-1"><strong>Total recebido:</strong> R$ <%= Number(recTotal).toFixed(2) %></p>
  <% if ((sale.recebimento_status || "quitado") === "pendente" || saldo > 0.02) { %>
    <p class="font-bold text-red-700">Saldo em aberto: R$ <%= Number(saldo).toFixed(2) %></p>
  <% } %>
  <% if ((sale.recebimento_status || "quitado") === "quitado" && recs.length === 0) { %>
    <% if (Number(sale.pagamento_dinheiro) > 0) { %>
      <p>Dinheiro: R$ <%= Number(sale.pagamento_dinheiro).toFixed(2) %></p>
    <% } %>
    <% if (Number(sale.pagamento_pix) > 0) { %>
      <p>Pix: R$ <%= Number(sale.pagamento_pix).toFixed(2) %></p>
    <% } %>
    <% if (Number(sale.pagamento_cartao) > 0) { %>
      <p>Cartão: R$ <%= Number(sale.pagamento_cartao).toFixed(2) %>
        <% if (Number(sale.parcelas) > 1) { %>(<%= sale.parcelas %>x)<% } %>
      </p>
    <% } %>
    <p>Valor pago: R$ <%= Number(sale.valor_pago).toFixed(2) %></p>
    <p>Troco: R$ <%= Number(sale.troco).toFixed(2) %></p>
  <% } %>
  <% if ((sale.recebimento_status || "quitado") === "quitado" && recs.length > 0) { %>
    <p class="text-xs text-slate-600 mt-1">Último recebimento — Valor pago: R$ <%= Number(sale.valor_pago).toFixed(2) %> · Troco: R$ <%= Number(sale.troco).toFixed(2) %></p>
  <% } %>
  <hr class="my-3" />
  <p class="text-center">Obrigado pela preferência!</p>
</div>
