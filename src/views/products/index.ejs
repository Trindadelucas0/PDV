<%- include("../partials/head", { title: "Produtos" }) %>
<%- include("../partials/sidebar") %>
<section class="bg-neutral-900 border border-amber-500/20 rounded-2xl p-6 mb-6">
  <div class="flex flex-wrap justify-between items-center gap-3">
    <div>
      <h2 class="text-3xl font-bold text-amber-100">Produtos</h2>
      <p class="text-sm text-slate-300 mt-1">Gerencie cadastro, estoque e precos de venda.</p>
    </div>
    <a href="/produtos/novo" class="bg-brand-500 hover:bg-brand-600 text-neutral-950 px-4 py-2 rounded-lg font-semibold transition-colors">Novo produto</a>
  </div>
</section>

<form method="get" class="mb-4">
  <input name="search" value="<%= search %>" placeholder="Buscar por nome ou codigo" class="w-full md:w-96 bg-neutral-900 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" />
</form>

<div class="bg-neutral-900 border border-amber-500/20 rounded-xl overflow-auto">
  <table class="w-full text-sm">
    <thead class="bg-neutral-950 text-amber-100">
      <tr>
        <th class="p-3 text-left">Nome</th><th class="p-3">Código</th><th class="p-3">Estoque</th><th class="p-3">Preço</th><th class="p-3">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach((p) => { %>
      <tr class="border-t border-slate-800 text-slate-200">
        <td class="p-3"><%= p.nome %></td>
        <td class="p-3 text-center text-slate-300"><%= p.codigo_barras %></td>
        <td class="p-3 text-center">
          <span class="<%= p.estoque <= 5 ? 'text-red-400 font-bold' : 'text-amber-200 font-medium' %>"><%= p.estoque %></span>
        </td>
        <td class="p-3 text-center text-amber-200 font-semibold">R$ <%= Number(p.preco).toFixed(2) %></td>
        <td class="p-3 text-center space-x-2">
          <a href="/produtos/<%= p.id %>/editar" class="text-amber-300 hover:text-amber-200">Editar</a>
          <form action="/produtos/<%= p.id %>?_method=DELETE" method="post" class="inline">
            <button class="text-red-400 hover:text-red-300" onclick="return confirm('Excluir produto?')">Excluir</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include("../partials/footer") %>
