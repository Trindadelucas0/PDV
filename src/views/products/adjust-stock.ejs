<%- include("../partials/head", { title: "Ajuste de estoque" }) %>
<%- include("../partials/sidebar") %>

<section class="bg-neutral-900 border border-amber-500/20 rounded-2xl p-6 mb-6">
  <h2 class="text-3xl font-bold text-amber-100 mb-1">Ajuste de estoque</h2>
  <p class="text-sm text-slate-300">Entrada de mercadoria, perda/quebra ou inventario (ajuste para quantidade contada).</p>
</section>

<% if (error) { %>
  <div class="mb-4 p-3 rounded-lg bg-red-900/30 text-red-200 border border-red-500/30"><%= error %></div>
<% } %>
<% if (success) { %>
  <div class="mb-4 p-3 rounded-lg bg-emerald-900/30 text-emerald-200 border border-emerald-500/30"><%= success %></div>
<% } %>

<div class="grid lg:grid-cols-2 gap-6">
  <form action="/produtos/estoque/ajustar" method="post" class="bg-neutral-900 rounded-xl border border-amber-500/20 p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-slate-300 mb-1">Produto</label>
      <select name="produto_id" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" required>
        <option value="">Selecione...</option>
        <% products.forEach((p) => { %>
          <option value="<%= p.id %>"><%= p.nome %> (atual: <%= p.estoque %>)</option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-300 mb-1">Tipo</label>
      <select name="tipo" id="tipo_mov" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" required>
        <option value="entrada">Entrada (compra / reposição)</option>
        <option value="perda">Perda / quebra / vencido</option>
        <option value="inventario">Inventario (informar estoque contado)</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-300 mb-1" id="lbl_qtd">Quantidade</label>
      <input name="quantidade" type="number" min="0" step="1" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" required />
      <p class="text-xs text-slate-400 mt-1" id="hint_qtd">Unidades a adicionar ao estoque.</p>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-300 mb-1">Motivo / observacao</label>
      <textarea name="motivo" rows="2" class="w-full bg-neutral-950 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="Ex.: NF 1234, avaria, contagem mensal"></textarea>
    </div>
    <button type="submit" class="bg-brand-500 hover:bg-brand-600 text-neutral-950 px-5 py-2 rounded-lg font-semibold">Registrar</button>
  </form>

  <div class="bg-neutral-900 rounded-xl border border-amber-500/20 p-6">
    <h3 class="font-semibold mb-3 text-amber-100">Ultimas movimentacoes</h3>
    <ul class="text-sm space-y-2 max-h-96 overflow-auto">
      <% movimentos.forEach((m) => { %>
        <li class="border-b border-slate-800 pb-2 text-slate-200">
          <span class="text-slate-400"><%= new Date(m.created_at).toLocaleString("pt-BR") %></span>
          · <strong><%= m.produto_nome %></strong>
          · <%= m.tipo %> · <strong><% if (m.tipo === "perda") { %>-<%= Math.abs(m.quantidade) %><% } else { %><%= m.quantidade > 0 ? "+" : "" %><%= m.quantidade %><% } %></strong>
          <% if (m.motivo) { %><br/><span class="text-slate-300"><%= m.motivo %></span><% } %>
        </li>
      <% }) %>
    </ul>
  </div>
</div>

<script>
  const tipo = document.getElementById("tipo_mov");
  const lbl = document.getElementById("lbl_qtd");
  const hint = document.getElementById("hint_qtd");
  function refresh() {
    if (tipo.value === "inventario") {
      lbl.textContent = "Estoque contado (novo total)";
      hint.textContent = "Informe a quantidade total apos a contagem.";
    } else if (tipo.value === "perda") {
      lbl.textContent = "Quantidade a dar baixa";
      hint.textContent = "Unidades retiradas do estoque.";
    } else {
      lbl.textContent = "Quantidade";
      hint.textContent = "Unidades a adicionar ao estoque.";
    }
  }
  tipo.addEventListener("change", refresh);
  refresh();
</script>

<%- include("../partials/footer") %>
