<%- include("../partials/head", { title: "Ajuste de estoque" }) %>
<%- include("../partials/sidebar") %>

<h2 class="text-2xl font-bold mb-2">Ajuste de estoque</h2>
<p class="text-sm text-slate-500 mb-6">Entrada de mercadoria, perda/quebra ou inventário (ajuste para quantidade contada).</p>

<% if (error) { %>
  <div class="mb-4 p-3 rounded-lg bg-red-50 text-red-800 border border-red-100"><%= error %></div>
<% } %>
<% if (success) { %>
  <div class="mb-4 p-3 rounded-lg bg-emerald-50 text-emerald-800 border border-emerald-100"><%= success %></div>
<% } %>

<div class="grid lg:grid-cols-2 gap-6">
  <form action="/produtos/estoque/ajustar" method="post" class="bg-white rounded-xl shadow border border-slate-100 p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Produto</label>
      <select name="produto_id" class="w-full border border-slate-300 rounded-lg px-3 py-2" required>
        <option value="">Selecione...</option>
        <% products.forEach((p) => { %>
          <option value="<%= p.id %>"><%= p.nome %> (atual: <%= p.estoque %>)</option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Tipo</label>
      <select name="tipo" id="tipo_mov" class="w-full border border-slate-300 rounded-lg px-3 py-2" required>
        <option value="entrada">Entrada (compra / reposição)</option>
        <option value="perda">Perda / quebra / vencido</option>
        <option value="inventario">Inventário (informar estoque contado)</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1" id="lbl_qtd">Quantidade</label>
      <input name="quantidade" type="number" min="0" step="1" class="w-full border border-slate-300 rounded-lg px-3 py-2" required />
      <p class="text-xs text-slate-500 mt-1" id="hint_qtd">Unidades a adicionar ao estoque.</p>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Motivo / observação</label>
      <textarea name="motivo" rows="2" class="w-full border border-slate-300 rounded-lg px-3 py-2" placeholder="Ex.: NF 1234, avaria, contagem mensal"></textarea>
    </div>
    <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white px-5 py-2 rounded-lg">Registrar</button>
  </form>

  <div class="bg-white rounded-xl shadow border border-slate-100 p-6">
    <h3 class="font-semibold mb-3">Últimas movimentações</h3>
    <ul class="text-sm space-y-2 max-h-96 overflow-auto">
      <% movimentos.forEach((m) => { %>
        <li class="border-b border-slate-100 pb-2">
          <span class="text-slate-500"><%= new Date(m.created_at).toLocaleString("pt-BR") %></span>
          · <strong><%= m.produto_nome %></strong>
          · <%= m.tipo %> · <strong><% if (m.tipo === "perda") { %>-<%= Math.abs(m.quantidade) %><% } else { %><%= m.quantidade > 0 ? "+" : "" %><%= m.quantidade %><% } %></strong>
          <% if (m.motivo) { %><br/><span class="text-slate-600"><%= m.motivo %></span><% } %>
        </li>
      <% }) %>
    </ul>
  </div>
</div>

<script>
  const tipo = document.getElementById("tipo_mov");
  const lbl = document.getElementById("lbl_qtd");
  const hint = document.getElementById("hint_qtd");
  function refresh() {
    if (tipo.value === "inventario") {
      lbl.textContent = "Estoque contado (novo total)";
      hint.textContent = "Informe a quantidade total após a contagem.";
    } else if (tipo.value === "perda") {
      lbl.textContent = "Quantidade a dar baixa";
      hint.textContent = "Unidades retiradas do estoque.";
    } else {
      lbl.textContent = "Quantidade";
      hint.textContent = "Unidades a adicionar ao estoque.";
    }
  }
  tipo.addEventListener("change", refresh);
  refresh();
</script>

<%- include("../partials/footer") %>
