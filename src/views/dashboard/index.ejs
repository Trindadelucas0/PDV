<%- include("../partials/head", { title: "Dashboard" }) %>
<%- include("../partials/sidebar") %>
<section class="bg-neutral-900 border border-amber-500/20 rounded-2xl p-6 mb-6">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-widest text-amber-300/90">Painel financeiro</p>
      <h2 class="text-3xl font-bold text-amber-100">Dashboard</h2>
      <p class="text-sm text-slate-300 mt-1">Visão geral de vendas, lucro e estoque.</p>
      <p class="text-xs text-slate-500 mt-2 max-w-xl">Totais do período consideram apenas vendas <strong class="text-slate-400">quitadas</strong> no caixa, pela data em que o pagamento foi registrado (ou data da venda nas antigas).</p>
    </div>
    <form method="get" class="flex flex-wrap items-end gap-3 bg-neutral-950/70 border border-amber-500/20 p-3 rounded-xl">
      <div>
        <label class="block text-xs text-slate-400 mb-1">De</label>
        <input type="date" name="de" value="<%= startDate %>" class="bg-neutral-900 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" />
      </div>
      <div>
        <label class="block text-xs text-slate-400 mb-1">Até</label>
        <input type="date" name="ate" value="<%= endDate %>" class="bg-neutral-900 border border-slate-700 text-slate-100 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500" />
      </div>
      <button class="bg-brand-500 hover:bg-brand-600 text-neutral-950 px-4 py-2 rounded-lg font-semibold transition-colors">Aplicar</button>
    </form>
  </div>
</section>

<div class="grid md:grid-cols-4 gap-4 mb-8">
  <div class="bg-neutral-900 border border-amber-500/20 rounded-xl p-5">
    <p class="text-slate-400 text-sm">Total vendido</p>
    <p class="text-3xl font-bold text-amber-300 mt-1">R$ <%= Number(totals.total_periodo).toFixed(2) %></p>
  </div>
  <div class="bg-neutral-900 border border-emerald-500/20 rounded-xl p-5">
    <p class="text-slate-400 text-sm">Lucro</p>
    <p class="text-3xl font-bold text-emerald-400 mt-1">R$ <%= Number(totals.lucro_periodo).toFixed(2) %></p>
  </div>
  <div class="bg-neutral-900 border border-amber-500/20 rounded-xl p-5">
    <p class="text-slate-400 text-sm">Vendas</p>
    <p class="text-3xl font-bold text-amber-100 mt-1"><%= totals.qtd_vendas %></p>
  </div>
  <div class="bg-neutral-900 border border-amber-500/20 rounded-xl p-5">
    <p class="text-slate-400 text-sm">Ticket médio</p>
    <p class="text-3xl font-bold text-amber-200 mt-1">R$ <%= Number(ticketMedio).toFixed(2) %></p>
  </div>
</div>

<div class="bg-neutral-900 border border-amber-500/20 rounded-xl p-5 mb-4">
  <h3 class="font-semibold mb-3 text-amber-100">Visão de estoque</h3>
  <div class="grid md:grid-cols-3 gap-4 text-sm">
    <div class="p-4 bg-neutral-950 rounded-lg border border-slate-800">
      <p class="text-slate-400">Unidades em estoque</p>
      <p class="text-2xl font-bold text-amber-200 mt-1"><%= Number(stockOverview.unidades_estoque) %></p>
    </div>
    <div class="p-4 bg-neutral-950 rounded-lg border border-slate-800">
      <p class="text-slate-400">Valor em custo</p>
      <p class="text-2xl font-bold text-slate-100 mt-1">R$ <%= Number(stockOverview.valor_custo_estoque).toFixed(2) %></p>
    </div>
    <div class="p-4 bg-neutral-950 rounded-lg border border-slate-800">
      <p class="text-slate-400">Valor em venda</p>
      <p class="text-2xl font-bold text-amber-200 mt-1">R$ <%= Number(stockOverview.valor_venda_estoque).toFixed(2) %></p>
    </div>
  </div>
</div>

<div class="bg-neutral-900 border border-amber-500/20 rounded-xl p-5 mb-4">
  <h3 class="font-semibold mb-3 text-amber-100">Evolução de vendas e lucro</h3>
  <canvas id="salesChart" height="95" class="bg-neutral-950 rounded-lg border border-slate-800 p-2"></canvas>
</div>

<div class="grid md:grid-cols-2 gap-4">
  <div class="bg-neutral-900 border border-amber-500/20 rounded-xl p-5">
    <h3 class="font-semibold mb-3 text-amber-100">Produtos com estoque baixo</h3>
    <ul class="space-y-2">
      <% lowStock.forEach((p) => { %>
        <li class="flex justify-between border-b border-slate-800 pb-2 text-slate-200">
          <span><%= p.nome %></span>
          <span class="text-red-400 font-semibold"><%= p.estoque %></span>
        </li>
      <% }) %>
    </ul>
  </div>
  <div class="bg-neutral-900 border border-amber-500/20 rounded-xl p-5">
    <h3 class="font-semibold mb-3 text-amber-100">Últimas vendas</h3>
    <ul class="space-y-2">
      <% latestSales.forEach((s) => { %>
        <li class="flex justify-between border-b border-slate-800 pb-2">
          <span class="text-slate-200">#<%= s.id %> - <%= s.cliente_nome || "Consumidor final" %></span>
          <span class="font-semibold text-amber-200">R$ <%= Number(s.total).toFixed(2) %></span>
        </li>
      <% }) %>
    </ul>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const chartRows = <%- JSON.stringify(chartRows || []) %>;
  const labels = chartRows.map((r) => new Date(r.dia).toLocaleDateString("pt-BR"));
  const totals = chartRows.map((r) => Number(r.total));
  const profits = chartRows.map((r) => Number(r.lucro));
  const canvas = document.getElementById("salesChart");
  if (canvas && labels.length) {
    new Chart(canvas, {
      type: "line",
      data: {
        labels,
        datasets: [
          {
            label: "Vendas (R$)",
            data: totals,
            borderWidth: 3,
            tension: 0.25,
            borderColor: "#f59e0b",
            backgroundColor: "rgba(245, 158, 11, 0.15)",
            pointBackgroundColor: "#f59e0b"
          },
          {
            label: "Lucro (R$)",
            data: profits,
            borderWidth: 3,
            tension: 0.25,
            borderColor: "#22c55e",
            backgroundColor: "rgba(34, 197, 94, 0.15)",
            pointBackgroundColor: "#22c55e"
          }
        ]
      },
      options: {
        responsive: true,
        plugins: { legend: { position: "bottom", labels: { color: "#e2e8f0" } } },
        scales: {
          x: { ticks: { color: "#cbd5e1" }, grid: { color: "rgba(148,163,184,.15)" } },
          y: { ticks: { color: "#cbd5e1" }, grid: { color: "rgba(148,163,184,.15)" } }
        }
      }
    });
  }
</script>
<%- include("../partials/footer") %>
